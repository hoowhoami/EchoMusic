{
  "name": "echo-music",
  "version": "2.2.0",
  "description": "EchoMusic desktop client.",
  "author": {
    "name": "hoowhoami",
    "email": "499196331@qq.com"
  },
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build && electron-builder",
    "build:win": "cd server && npm install --omit=dev && cd .. && vue-tsc --noEmit && vite build && electron-builder --win --x64",
    "build:mac": "cd server && npm install --omit=dev && cd .. && vue-tsc --noEmit && vite build && electron-builder --mac",
    "build:linux": "cd server && npm install --omit=dev && cd .. && vue-tsc --noEmit && vite build && electron-builder --linux",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.ts,.jsx,.tsx --fix",
    "format": "prettier --write \"src/**/*.{vue,ts,js,json}\" \"vite.config.mts\" \"tsconfig*.json\""
  },
  "dependencies": {
    "@iconify/icons-tabler": "^1.2.95",
    "@iconify/types": "^2.0.0",
    "@iconify/vue": "^5.0.0",
    "@vueuse/core": "^14.2.1",
    "axios": "^1.13.6",
    "conf": "^15.1.0",
    "electron-log": "^5.4.3",
    "howler": "^2.2.4",
    "pinia": "^2.3.1",
    "pinia-plugin-persistedstate": "^4.2.0",
    "reka-ui": "^2.9.2",
    "semver": "^7.7.4",
    "sortablejs": "^1.15.7",
    "vue": "^3.5.30",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/howler": "^2.2.12",
    "@types/node": "^22.13.9",
    "@types/semver": "^7.7.1",
    "@types/sortablejs": "^1.15.9",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "autoprefixer": "^10.4.27",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.8.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.7.3",
    "vite": "^6.2.0",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vue-tsc": "^2.2.8"
  },
  "build": {
    "appId": "com.hoowhoami.echomusic",
    "productName": "EchoMusic",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist",
      "dist-electron"
    ],
    "extraResources": [
      {
        "from": "build/icons",
        "to": "icons",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "server/module",
        "to": "server/module",
        "filter": ["**/*.js"]
      },
      {
        "from": "server/util",
        "to": "server/util",
        "filter": ["**/*.js", "**/*.json"]
      },
      {
        "from": "server/node_modules",
        "to": "server/node_modules"
      }
    ],
    "mac": {
      "icon": "icons/icon.icns",
      "category": "public.app-category.music",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "icon": "icons/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "linux": {
      "icon": "build/icons/linux_256x256.png",
      "target": [
        "AppImage",
        "deb",
        "rpm",
        "tar.gz"
      ]
    },
    "deb": {
      "depends": [
        "libasound2"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "include": "build/installer.nsh",
      "artifactName": "${productName}-${version}-Windows-Setup-${arch}.${ext}"
    },
    "dmg": {
      "artifactName": "${productName}-${version}-macOS-${arch}.${ext}",
      "backgroundColor": "#ffffff",
      "window": {
        "width": 660,
        "height": 400
      },
      "contents": [
        {
          "x": 180,
          "y": 170,
          "type": "file"
        },
        {
          "x": 480,
          "y": 170,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller"
    ],
    "ignoredBuiltDependencies": [
      "electron",
      "esbuild",
      "vue-demi"
    ]
  }
}
