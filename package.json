{
  "name": "echo-music",
  "version": "2.2.6-beta.8",
  "description": "EchoMusic desktop client.",
  "author": {
    "name": "hoowhoami",
    "email": "hoowhoami@qq.com"
  },
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build && electron-builder",
    "build:win": "cd server && npm install --omit=dev && cd .. && vue-tsc --noEmit && vite build && electron-builder --win --x64",
    "build:mac": "cd server && npm install --omit=dev && cd .. && vue-tsc --noEmit && vite build && electron-builder --mac",
    "build:linux": "cd server && npm install --omit=dev && cd .. && vue-tsc --noEmit && vite build && electron-builder --linux",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.ts,.jsx,.tsx --fix",
    "analyze": "ANALYZE_BUNDLE=1 vite build",
    "format": "prettier --write \"src/**/*.{vue,ts,js,json}\" \"vite.config.mts\" \"tsconfig*.json\""
  },
  "dependencies": {
    "@iconify/icons-tabler": "^1.2.95",
    "@iconify/types": "^2.0.0",
    "@iconify/vue": "^5.0.1",
    "@vueuse/core": "^14.3.0",
    "axios": "^1.16.1",
    "electron-audio-loopback": "^1.0.6",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.3",
    "font-list": "^2.1.0",
    "marked": "^18.0.4",
    "pinia": "^3.0.4",
    "reka-ui": "^2.9.8",
    "semver": "^7.8.1",
    "shazam-api": "^0.3.0",
    "sortablejs": "^1.15.7",
    "vue": "^3.5.35",
    "vue-router": "^4.6.4",
    "yzs-keep-alive-v3": "^0.1.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/semver": "^7.7.1",
    "@types/sortablejs": "^1.15.9",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "autoprefixer": "^10.5.0",
    "electron": "42.3.1",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-vue": "^10.9.1",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.14",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.7",
    "vue-tsc": "^3.3.3"
  },
  "build": {
    "appId": "com.hoowhoami.echomusic",
    "productName": "EchoMusic",
    "publish": [
      {
        "provider": "github",
        "owner": "hoowhoami",
        "repo": "EchoMusic"
      }
    ],
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "afterPack": "./build/afterPack.js",
    "files": [
      "dist",
      "dist-electron"
    ],
    "extraResources": [
      {
        "from": "native/echo-media-controls/echo-media-controls.node",
        "to": "native/echo-media-controls.node",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "native/echo-mpv-player/echo-mpv-player.node",
        "to": "native/echo-mpv-player.node",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "native/echo-storage/echo-storage.node",
        "to": "native/echo-storage.node",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "build/mpv",
        "to": "mpv",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "build/icons",
        "to": "icons",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "CHANGELOG.md",
        "to": "CHANGELOG.md"
      },
      {
        "from": "server/module",
        "to": "server/module",
        "filter": [
          "**/*.js"
        ]
      },
      {
        "from": "server/util",
        "to": "server/util",
        "filter": [
          "**/*.js",
          "**/*.json"
        ]
      },
      {
        "from": "server/node_modules",
        "to": "server/node_modules"
      }
    ],
    "mac": {
      "icon": "icons/icon.icns",
      "category": "public.app-category.music",
      "target": [
        "zip",
        "dmg"
      ]
    },
    "win": {
      "icon": "icons/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "linux": {
      "icon": "build/icons/linux_256x256.png",
      "target": [
        "AppImage",
        "deb",
        "rpm",
        "tar.gz"
      ]
    },
    "deb": {
      "depends": [
        "libasound2",
        "libmpv2 | libmpv1"
      ]
    },
    "rpm": {
      "depends": [
        "mpv-libs"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "include": "build/installer.nsh",
      "artifactName": "${productName}-${version}-Windows-Setup-${arch}.${ext}"
    },
    "dmg": {
      "artifactName": "${productName}-${version}-macOS-${arch}.${ext}",
      "backgroundColor": "#ffffff",
      "window": {
        "width": 660,
        "height": 400
      },
      "contents": [
        {
          "x": 180,
          "y": 170,
          "type": "file"
        },
        {
          "x": 480,
          "y": 170,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller"
    ],
    "ignoredBuiltDependencies": [
      "esbuild",
      "vue-demi"
    ]
  }
}
